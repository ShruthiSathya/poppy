from abc import ABC, abstractmethod
from src.scoring.candidate import CandidatePair
import logging

class BaseLayer(ABC):
    """
    Every scoring layer must implement score().
    If scoring fails, it logs and returns the pair unchanged — 
    never crashes the pipeline.
    """
    layer_name: str = "base"
    version: str = "1.0"

    def __init__(self, config: dict):
        self.config = config
        self.logger = logging.getLogger(self.__class__.__name__)

    def run(self, pair: CandidatePair) -> CandidatePair:
        # Check if pair is already disqualified — skip expensive computation
        if pair.flags.existing_patent_on_indication:
            self.logger.info(f"Skipping {self.layer_name} — pair disqualified")
            return pair
